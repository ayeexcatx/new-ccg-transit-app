{
  "name": "Dispatch",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Company ID"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Dispatch date"
    },
    "shift_time": {
      "type": "string",
      "enum": [
        "Day Shift",
        "Night Shift"
      ],
      "description": "Shift type"
    },
    "client_name": {
      "type": "string",
      "description": "Client name"
    },
    "job_number": {
      "type": "string",
      "description": "Job number"
    },
    "reference_tag": {
      "type": "string",
      "required": false
    },
    "start_time": {
      "type": "string",
      "description": "Start time"
    },
    "start_location": {
      "type": "string",
      "description": "Starting location"
    },
    "instructions": {
      "type": "string",
      "default": "Deliver material to / from",
      "description": "Dispatch instructions"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes"
    },
    "toll_status": {
      "type": "string",
      "enum": [
        "Authorized",
        "Unauthorized",
        "Included in Rate"
      ],
      "description": "Toll authorization status"
    },
    "trucks_assigned": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Truck numbers assigned"
    },
    "truck_overrides": {
      "type": "array",
      "required": false,
      "items": {
        "type": "object",
        "properties": {
          "truck_number": {
            "type": "string"
          },
          "start_time": {
            "type": "string"
          },
          "start_location": {
            "type": "string"
          },
          "instructions": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "description": "Optional per-truck overrides for Assignment 1 details"
    },
    "status": {
      "type": "string",
      "enum": [
        "Scheduled",
        "Dispatch",
        "Amended",
        "Cancelled"
      ],
      "default": "Scheduled",
      "description": "Dispatch status"
    },
    "edit_locked": {
      "type": "boolean",
      "default": false,
      "description": "Whether this dispatch is currently locked for editing"
    },
    "edit_locked_by_session_id": {
      "type": "string",
      "description": "Session ID of the admin currently editing this dispatch"
    },
    "edit_locked_by_name": {
      "type": "string",
      "description": "Name or code of the admin currently editing this dispatch"
    },
    "edit_locked_at": {
      "type": "string",
      "description": "When the dispatch was locked for editing (ISO datetime)"
    },
    "admin_activity_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "description": "When the admin activity occurred (ISO datetime)"
          },
          "admin_session_id": {
            "type": "string",
            "description": "Session ID of the admin who performed the action"
          },
          "admin_name": {
            "type": "string",
            "description": "Name or identifier of the admin who performed the action"
          },
          "action": {
            "type": "string",
            "description": "Activity action type"
          },
          "message": {
            "type": "string",
            "description": "Human-readable description of the activity"
          }
        }
      },
      "description": "Admin-only activity history for this dispatch"
    },
    "additional_assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "job_number": {
            "type": "string"
          },
          "reference_tag": {
            "type": "string",
            "required": false
          },
          "start_time": {
            "type": "string"
          },
          "start_location": {
            "type": "string"
          },
          "instructions": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "toll_status": {
            "type": "string",
            "enum": [
              "Authorized",
              "Unauthorized",
              "Included in Rate"
            ]
          }
        }
      },
      "description": "Additional assignments"
    },
    "amendment_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "amended_at": {
            "type": "string"
          },
          "changes": {
            "type": "string"
          }
        }
      },
      "description": "Amendment history"
    },
    "canceled_reason": {
      "type": "string",
      "description": "Reason for cancellation"
    },
    "archived_flag": {
      "type": "boolean",
      "default": false,
      "description": "Whether this dispatch is archived"
    },
    "archived_at": {
      "type": "string",
      "description": "When the dispatch was archived (ISO datetime)"
    },
    "archived_reason": {
      "type": "string",
      "description": "Reason for archiving (e.g. Time logged, Admin archived)"
    },
    "dispatch_html_drive_records": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dispatch_id": {
            "type": "string"
          },
          "truck_number": {
            "type": "string"
          },
          "file_id": {
            "type": "string",
            "required": false
          },
          "file_name": {
            "type": "string"
          },
          "company_folder_name": {
            "type": "string"
          },
          "truck_folder_name": {
            "type": "string"
          },
          "path_key": {
            "type": "string"
          },
          "root_folder_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "synced_at": {
            "type": "string"
          }
        }
      },
      "description": "Google Drive HTML sync records for this dispatch, one per truck file"
    },
    "dispatch_html_drive_root_folder_id": {
      "type": "string",
      "description": "Google Drive root folder ID used for HTML dispatch sync"
    },
    "dispatch_html_drive_last_synced_at": {
      "type": "string",
      "description": "Last successful HTML Drive sync timestamp"
    },
    "dispatch_html_drive_last_sync_status": {
      "type": "string",
      "enum": [
        "pending",
        "synced",
        "failed",
        "finalized"
      ],
      "description": "Most recent HTML Drive sync state"
    },
    "dispatch_html_drive_last_sync_error": {
      "type": "string",
      "description": "Last HTML Drive sync error message"
    },
    "dispatch_html_drive_sync_finalized_at": {
      "type": "string",
      "description": "When HTML Drive sync was finalized after archive"
    },
    "live_truck_statuses": {
      "type": "object",
      "description": "Per-truck live status labels for the live dispatch board, keyed by truck number"
    }
  },
  "required": [
    "company_id",
    "date",
    "shift_time",
    "trucks_assigned"
  ],
  "rls": {
    "delete": {
      "user_condition": {
        "data.app_role": "admin"
      }
    },
    "create": {
      "user_condition": {
        "data.app_role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "data.app_role": "admin"
          }
        },
        {
          "data.company_id": "{{user.data.company_id}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "data.app_role": "admin"
          }
        },
        {
          "data.company_id": "{{user.data.company_id}}"
        }
      ]
    }
  }
}
